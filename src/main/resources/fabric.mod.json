{
	"schemaVersion": 1,
	"id": "yubbymod",
	"version": "${version}",
	"name": "YubbyMod",
	"description": "The official YubbyMod by YubbyWawa!",
	"authors": [
		"YubbyWawa"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/yubbymod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.yubbywawa.yubbymod.YubbyMod"
		],
		"fabric-datagen": [
			"net.yubbywawa.yubbymod.YubbyModDataGenerator"
		],
		"client": [
			"net.yubbywawa.yubbymod.YubbyModClient"
		]
	},
	"mixins": [
		"yubbymod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	}
